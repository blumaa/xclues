# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase URL (from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Publishable Key (from your Supabase project settings - safe to expose)
# IMPORTANT: Use the "Publishable key", NOT the "Secret key"!
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# Supabase Service Role Key (server-only, for reading analytics on /analidiots)
# NEVER expose this to the browser. Used only in server components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
